@model web1.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var relatedProducts = ViewBag.RelatedProducts as List<web1.Models.Product>;
    var variants = ViewBag.Variants as List<web1.Models.ProductVariant>;
    var availableSizes = ViewBag.AvailableSizes as List<string> ?? new List<string>();
    var availableColors = ViewBag.AvailableColors as List<string> ?? new List<string>();
}

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" class="text-decoration-none text-muted">Sản phẩm</a></li>
            <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    @if (TempData["ReviewSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["ReviewSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ReviewError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["ReviewError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-5">
        <!-- Product Images -->
        <div class="col-lg-7">
            <div class="position-sticky" style="top: 100px;">
                <div class="rounded-4 overflow-hidden shadow-lg border">
                    <img src="@Model.ImageUrl" class="img-fluid w-100" alt="@Model.Name" style="object-fit: cover; aspect-ratio: 1/1;" onerror="this.src='https://placehold.co/500x500/f5f5f5/94943c?text=Nike'">
                </div>
                <div class="d-flex gap-2 mt-3">
                    <img src="@Model.ImageUrl" class="rounded border active p-1 shadow-sm" style="width: 80px; height: 80px; cursor: pointer; border-color: var(--primary-color) !important;" onerror="this.src='https://placehold.co/80x80/f5f5f5/94943c?text=Nike'" onclick="this.closest('div').previousElementSibling.querySelector('img').src=this.src">
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="col-lg-5">
            <div class="ps-lg-2">
                <span class="badge bg-soft-primary text-primary mb-2">@(Model.Category?.Name ?? "Fashion Store")</span>
                <h1 class="fw-black mb-3 text-uppercase" style="font-size: 2.25rem; letter-spacing: -0.02em;">@Model.Name</h1>

                <!-- Rating -->
                <div class="d-flex align-items-center mb-4 pb-4 border-bottom flex-wrap gap-2">
                    <div class="text-warning">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fas fa-star @(i <= (int)Math.Round((double)(Model.Rating ?? 0)) ? "" : "text-muted opacity-25")"></i>
                        }
                    </div>
                    <span class="fw-bold">@((Model.Rating ?? 0).ToString("F1"))</span>
                    <span class="text-muted">|</span>
                    <span class="text-muted small">@Model.ReviewCount đánh giá</span>
                    <span class="text-muted">|</span>
                    <span class="text-danger small fw-bold">
                        <i class="fas fa-fire me-1"></i>@(Model.SoldCount ?? 0) đã bán
                    </span>
                </div>

                <!-- Price -->
                <div class="mb-4">
                    <div class="d-flex align-items-baseline gap-2">
                        <div class="h2 fw-bold text-primary mb-0 font-outfit" id="display-price">@((Model.Price ?? 0).ToString("N0"))đ</div>
                    </div>
                </div>

                <!-- Short Description -->
                <p class="text-muted mb-4 lead" style="font-size: 1rem;">@Model.Description</p>

                <!-- ═══════════════════════════════════════════════
                     VARIANT SELECTION PANEL - Size + Color động
                     ═══════════════════════════════════════════════ -->
                <div class="bg-light rounded-4 p-4 mb-4 border">

                    <!-- Size Selection -->
                    <div class="mb-4" id="size-section">
                        <div class="d-flex justify-content-between mb-2">
                            <h6 class="fw-bold mb-0">Kích thước</h6>
                            <a href="#" class="small text-primary text-decoration-none">Bảng size</a>
                        </div>
                        @if (availableSizes.Any())
                        {
                            <div class="d-flex flex-wrap gap-2" id="size-selector">
                                @foreach (var size in availableSizes)
                                {
                                    <input type="radio" class="btn-check" name="size" id="size-@size" value="@size">
                                    <label class="btn btn-outline-dark rounded-pill px-3 variant-size-btn" for="size-@size">@size</label>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Sản phẩm này chưa có thông tin kích thước.</p>
                        }
                    </div>

                    <!-- Color Selection -->
                    <div class="mb-4" id="color-section">
                        <h6 class="fw-bold mb-2">Màu sắc</h6>
                        @if (availableColors.Any())
                        {
                            <div class="d-flex flex-wrap gap-2" id="color-selector">
                                @foreach (var color in availableColors)
                                {
                                    <input type="radio" class="btn-check" name="color" id="color-@color" value="@color">
                                    <label class="btn btn-outline-dark rounded-pill px-3 variant-color-btn" for="color-@color">@color</label>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Sản phẩm này chưa có thông tin màu sắc.</p>
                        }
                    </div>

                    <!-- Stock Status -->
                    <div id="stock-status" class="mb-3" style="display:none">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fas fa-circle text-success small" id="stock-icon"></i>
                            <span class="small fw-bold" id="stock-text"></span>
                        </div>
                    </div>

                    <!-- Quantity -->
                    <div>
                        <h6 class="fw-bold mb-2">Số lượng</h6>
                        <div class="input-group rounded-pill border overflow-hidden quantity-control" style="width: 140px; background: white;">
                            <button class="btn border-0 px-3 hover-bg-light" type="button" onclick="decreaseQuantity()"><i class="fas fa-minus small"></i></button>
                            <input type="number" class="form-control text-center border-0 fw-bold" id="quantity" value="1" min="1" style="box-shadow: none;">
                            <button class="btn border-0 px-3 hover-bg-light" type="button" onclick="increaseQuantity()"><i class="fas fa-plus small"></i></button>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="row g-2 mb-4">
                    <div class="col-8">
                        <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm add-to-cart py-3"
                                id="add-to-cart-btn"
                                @(availableSizes.Count == 0 && availableColors.Count == 0 ? "" : "disabled")>
                            <i class="fas fa-shopping-bag me-2"></i>
                            <span id="add-to-cart-text">
                                @(availableSizes.Count == 0 && availableColors.Count == 0
                                    ? "Thêm vào giỏ"
                                    : "Chọn Size & Màu")
                            </span>
                        </button>
                    </div>
                    <div class="col-4">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <button class="btn btn-outline-dark btn-lg w-100 rounded-pill py-3 @(ViewBag.IsInWishlist == true ? "text-danger border-danger" : "")"
                                    id="wishlist-btn"
                                    data-product-id="@Model.Id">
                                <i class="fa-heart @(ViewBag.IsInWishlist == true ? "fas text-danger" : "far")"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-dark btn-lg w-100 rounded-pill py-3"
                                    onclick="location.href='@Url.Action("Login", "Account", new { returnUrl = Url.Action("Details", "Products", new { id = Model.Id }) })'">
                                <i class="far fa-heart"></i>
                            </button>
                        }
                    </div>
                </div>

                <!-- Shipping Info -->
                <div class="bg-white rounded-4 border p-3 d-flex flex-column gap-2">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="text-primary mt-1"><i class="fas fa-truck-moving"></i></div>
                        <div>
                            <div class="fw-bold small">Giao hàng nhanh miễn phí</div>
                            <div class="extra-small text-muted">Với đơn hàng trên 500.000đ</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start">
                        <div class="text-primary mt-1"><i class="fas fa-undo"></i></div>
                        <div>
                            <div class="fw-bold small">Đổi trả miễn phí trong 30 ngày</div>
                            <div class="extra-small text-muted">Nếu không vừa hoặc lỗi sản xuất</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs Section -->
    <div class="mt-5 pt-5">
        <ul class="nav nav-pills justify-content-center mb-4 gap-2" id="productTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active rounded-pill px-4 fw-bold shadow-sm" id="description-tab" data-bs-toggle="tab" data-bs-target="#description-pane" type="button">Mô tả sản phẩm</button>
            </li>
            <li class="nav-item">
                <button class="nav-link rounded-pill px-4 fw-bold shadow-sm" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-pane" type="button">Đánh giá (@Model.ReviewCount)</button>
            </li>
        </ul>
        <div class="tab-content bg-white p-4 rounded-4 shadow-sm border" id="productTabsContent">
            <div class="tab-pane fade show active" id="description-pane" role="tabpanel">
                <div class="row g-4">
                    <div class="col-md-8">
                        <h4 class="fw-bold mb-3">Chi tiết sản phẩm</h4>
                        <p class="text-muted">@Model.Description</p>
                        <p class="text-muted">Luôn hướng tới sự hoàn hảo, sản phẩm được thiết kế với chất liệu cao cấp nhất mang lại cảm giác thoải mái suốt ngày dài. Đường may tinh tế, form dáng hiện đại phù hợp với nhiều phong cách khác nhau.</p>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light p-3 rounded-4">
                            <h5 class="fw-bold mb-3">Thông số</h5>
                            <table class="table table-sm table-borderless mb-0">
                                <tr><td class="text-muted small">Mã sản phẩm:</td><td class="fw-bold small text-end">#SP@(Model.Id.ToString("D4"))</td></tr>
                                <tr><td class="text-muted small">Danh mục:</td><td class="fw-bold small text-end">@(Model.Category?.Name ?? "Tất cả")</td></tr>
                                <tr><td class="text-muted small">Chất liệu:</td><td class="fw-bold small text-end">Cotton cao cấp</td></tr>
                                <tr><td class="text-muted small">Ngày ra mắt:</td><td class="fw-bold small text-end">@(Model.CreatedDate?.ToString("dd/MM/yyyy") ?? "N/A")</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="reviews-pane" role="tabpanel">
                <div class="row g-5">
                    <!-- Average Rating -->
                    <div class="col-md-4 border-end">
                        <div class="text-center py-4">
                            <div class="fw-black text-primary mb-0" style="font-size: 4.5rem; line-height: 1;">@((Model.Rating ?? 0).ToString("F1"))</div>
                            <div class="text-warning mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star fa-lg @(i <= (int)Math.Round((double)(Model.Rating ?? 0)) ? "" : "text-muted opacity-25")"></i>
                                }
                            </div>
                            <p class="text-muted fw-medium">Dựa trên @(Model.ReviewCount ?? 0) đánh giá</p>

                            <hr class="my-4 mx-auto w-75">

                            <h6 class="fw-bold mb-3">Gửi đánh giá của bạn</h6>
                            <form asp-action="AddReview" method="post" id="review-form">
                                <input type="hidden" name="ProductId" value="@Model.Id" />

                                <div class="mb-3">
                                    <div class="star-rating fs-4 text-muted d-flex justify-content-center gap-1">
                                        <i class="far fa-star cursor-pointer hover-text-warning" data-val="1"></i>
                                        <i class="far fa-star cursor-pointer hover-text-warning" data-val="2"></i>
                                        <i class="far fa-star cursor-pointer hover-text-warning" data-val="3"></i>
                                        <i class="far fa-star cursor-pointer hover-text-warning" data-val="4"></i>
                                        <i class="far fa-star cursor-pointer hover-text-warning" data-val="5"></i>
                                    </div>
                                    <input type="hidden" name="Rating" id="rating-input" value="5" />
                                </div>

                                @if (!User.Identity?.IsAuthenticated ?? true)
                                {
                                    <div class="form-floating mb-3">
                                        <input type="text" name="CustomerName" class="form-control rounded-3" id="cusName" placeholder="Họ tên" required>
                                        <label for="cusName">Họ tên của bạn</label>
                                    </div>
                                }
                                else
                                {
                                    <input type="hidden" name="CustomerName" value="Logged-in User" />
                                }

                                <div class="form-floating mb-3">
                                    <textarea name="Content" class="form-control rounded-3" id="reviewText" placeholder="Nhận xét" style="height: 100px" required></textarea>
                                    <label for="reviewText">Nhận xét của bạn...</label>
                                </div>

                                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">Gửi đánh giá</button>
                            </form>
                        </div>
                    </div>

                    <!-- Review List -->
                    <div class="col-md-8">
                        <div class="review-list">
                            @{
                                var reviews = ViewBag.Reviews as List<web1.Models.Review>;
                            }
                            @if (reviews != null && reviews.Any())
                            {
                                @foreach (var review in reviews)
                                {
                                    <div class="review-item mb-4 pb-4 border-bottom">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="fw-bold text-dark">@review.CustomerName</div>
                                            <div class="text-muted small">@review.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                        <div class="text-warning mb-2" style="font-size: 0.85rem;">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= review.Rating ? "" : "text-muted opacity-25")"></i>
                                            }
                                        </div>
                                        <p class="text-muted mb-0">@review.Content</p>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="far fa-comment-dots fa-3x text-muted mb-3 opacity-25"></i>
                                    <p class="text-muted">Chưa có đánh giá nào cho sản phẩm này.<br>Hãy là người đầu tiên đánh giá!</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (relatedProducts != null && relatedProducts.Any())
    {
        <div class="mt-5">
            <h3 class="mb-4">Sản phẩm liên quan</h3>
            <div class="row g-4">
                @foreach (var product in relatedProducts)
                {
                    <div class="col-lg-3 col-md-6 mb-4">
                        <div class="product-card-modern clickable-card h-100" onclick="location.href='@Url.Action("Details", "Products", new { id = product.Id })'">
                            <div class="product-card-image-wrapper" style="aspect-ratio: 1/1; overflow: hidden;">
                                <img src="@product.ImageUrl" class="product-card-image w-100 h-100" style="object-fit: cover;" alt="@product.Name" onerror="this.src='https://placehold.co/300x300/f5f5f5/94943c?text=Nike'">
                            </div>
                            <div class="product-card-body p-3">
                                <h6 class="product-card-name text-truncate mb-1" title="@product.Name">@product.Name</h6>
                                <div class="mb-2 text-warning tiny-star">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= (int)Math.Round((double)(product.Rating ?? 0)) ? "" : "text-muted opacity-25")"></i>
                                    }
                                </div>
                                <div class="product-card-footer pt-2">
                                    <span class="product-card-price" style="font-size: 1.1rem;">@((product.Price ?? 0).ToString("N0"))đ</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // ═══════════════════════════════════════════════════════
        // VARIANT DATA - Dữ liệu biến thể từ server
        // ═══════════════════════════════════════════════════════
        var productId = @Model.Id;
        var basePrice = @(Model.Price ?? 0);
        var variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            (variants ?? new List<web1.Models.ProductVariant>())
            .Select(v => new { v.Size, v.Color, v.Stock, v.PriceModifier, v.IsActive })
        ));
        var availableSizes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(availableSizes));

        var selectedSize = null;
        var selectedColor = null;
        var currentStock = 0;

        // ═══════════════════════════════════════════════════════
        // Quantity controls
        // ═══════════════════════════════════════════════════════
        function increaseQuantity() {
            var qty = parseInt($('#quantity').val()) || 1;
            var max = currentStock;
            if (max > 0 && qty < max) {
                $('#quantity').val(qty + 1);
            } else if (max <= 0) {
                if (typeof showToast === 'function') showToast('Sản phẩm này đã hết hàng!', 'error');
            } else {
                if (typeof showToast === 'function') showToast('Đã đạt giới hạn tồn kho!', 'error');
            }
        }

        function decreaseQuantity() {
            var qty = parseInt($('#quantity').val()) || 1;
            if (qty > 1) $('#quantity').val(qty - 1);
        }

        // ═══════════════════════════════════════════════════════
        // Update UI khi chọn Size/Color
        // ═══════════════════════════════════════════════════════
        function updateVariantUI() {
            var stockStatus = $('#stock-status');
            var addBtn = $('#add-to-cart-btn');
            var addText = $('#add-to-cart-text');
            var priceDisplay = $('#display-price');

            if (!selectedSize || !selectedColor) {
                // Chưa chọn đủ Size + Color
                stockStatus.hide();
                addBtn.prop('disabled', true);
                addText.text('Chọn Size & Màu');
                priceDisplay.text(basePrice.toLocaleString('vi-VN') + 'đ');
                return;
            }

            // Tìm variant tương ứng
            var variant = variants.find(v => v.Size == selectedSize && v.Color == selectedColor);

            if (!variant || !variant.IsActive) {
                // Biến thể không tồn tại hoặc bị ẩn
                currentStock = 0;
                stockStatus.show();
                $('#stock-icon').removeClass('text-success text-warning text-danger').addClass('text-danger');
                $('#stock-icon').attr('data-fa-i2svg', '');
                $('#stock-text').removeClass('text-success text-warning text-danger').addClass('text-danger').text('Không có biến thể này');
                addBtn.prop('disabled', true);
                addText.text('Hết hàng');
                priceDisplay.text(basePrice.toLocaleString('vi-VN') + 'đ');
                $('#quantity').val(1).prop('max', 0);
                return;
            }

            currentStock = variant.Stock;
            var effectivePrice = basePrice + (variant.PriceModifier || 0);
            priceDisplay.text(effectivePrice.toLocaleString('vi-VN') + 'đ');

            // Hiển thị tồn kho
            stockStatus.show();
            $('#quantity').val(1).prop('max', currentStock);

            if (currentStock <= 0) {
                $('#stock-icon').removeClass('text-success text-warning').addClass('text-danger');
                $('#stock-text').removeClass('text-success text-warning').addClass('text-danger').text('Hết hàng');
                addBtn.prop('disabled', true);
                addText.text('Hết hàng');
            } else if (currentStock <= 5) {
                $('#stock-icon').removeClass('text-success text-danger').addClass('text-warning');
                $('#stock-text').removeClass('text-success text-danger').addClass('text-warning').text('Chỉ còn ' + currentStock + ' cái!');
                addBtn.prop('disabled', false);
                addText.text('Thêm vào giỏ');
            } else {
                $('#stock-icon').removeClass('text-warning text-danger').addClass('text-success');
                $('#stock-text').removeClass('text-warning text-danger').addClass('text-success').text('Còn ' + currentStock + ' cái');
                addBtn.prop('disabled', false);
                addText.text('Thêm vào giỏ');
            }
        }

        // ═══════════════════════════════════════════════════════
        // Event: chọn Size
        // ═══════════════════════════════════════════════════════
        $(document).on('change', 'input[name="size"]', function() {
            selectedSize = $(this).val();
            // Khi đổi Size → reset Color đã chọn
            selectedColor = null;
            $('input[name="color"]').prop('checked', false);
            updateVariantUI();
        });

        // ═══════════════════════════════════════════════════════
        // Event: chọn Color
        // ═══════════════════════════════════════════════════════
        $(document).on('change', 'input[name="color"]', function() {
            selectedColor = $(this).val();
            updateVariantUI();
        });

        // ═══════════════════════════════════════════════════════
        // Add to Cart
        // ═══════════════════════════════════════════════════════
        $(document).ready(function() {
            // Add to cart button
            $('#add-to-cart-btn').click(function(event) {
                if (!selectedSize || !selectedColor) {
                    if (typeof showToast === 'function') showToast('Vui lòng chọn Size và Màu sắc!', 'error');
                    return;
                }

                var quantity = parseInt($('#quantity').val()) || 1;
                addToCart(productId, quantity, selectedSize, selectedColor, event);
            });

            // ── Wishlist Toggle ────────────────────────────────────────
            $('#wishlist-btn').click(function() {
                var btn = $(this);
                var pid = btn.data('product-id');

                $.ajax({
                    url: '@Url.Action("ToggleWishlist", "Products")',
                    type: 'POST',
                    data: { productId: pid },
                    success: function(res) {
                        if (res.success) {
                            if (res.action === 'added') {
                                btn.removeClass('text-danger border-danger')
                                   .find('i').removeClass('far').addClass('fas text-danger');
                                if (typeof showToast === 'function')
                                    showToast(res.message, 'success');
                            } else {
                                btn.addClass('text-danger border-danger')
                                   .find('i').removeClass('fas text-danger').addClass('far');
                                if (typeof showToast === 'function')
                                    showToast(res.message, 'info');
                            }
                        } else {
                            if (typeof showToast === 'function')
                                showToast(res.message, 'error');
                        }
                    },
                    error: function() {
                        if (typeof showToast === 'function')
                            showToast('Đã xảy ra lỗi. Vui lòng thử lại.', 'error');
                    }
                });
            });

            // ── Star Rating ─────────────────────────────────────────────
            $('.star-rating i').on('mouseenter', function() {
                var val = $(this).data('val');
                $(this).prevAll().addBack().removeClass('far').addClass('fas text-warning');
                $(this).nextAll().removeClass('fas text-warning').addClass('far');
            }).on('mouseleave', function() {
                updateStars($('#rating-input').val());
            }).on('click', function() {
                var val = $(this).data('val');
                $('#rating-input').val(val);
                updateStars(val);
            });

            function updateStars(val) {
                $('.star-rating i').each(function() {
                    if ($(this).data('val') <= val) {
                        $(this).removeClass('far').addClass('fas text-warning');
                    } else {
                        $(this).removeClass('fas text-warning').addClass('far');
                    }
                });
            }

            updateStars($('#rating-input').val());
        });
    </script>
}

