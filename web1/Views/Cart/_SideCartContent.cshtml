@model List<CartItem>

<div class="side-cart-items-wrapper">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-shopping-cart fa-3x text-muted mb-3 opacity-25"></i>
            <p class="text-muted">Giỏ hàng của bạn đang trống.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-2">Mua sắm ngay</a>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <div class="cart-item-mini">
                <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name">
                <div class="cart-item-info">
                    <h6 class="cart-item-title line-clamp-2 mb-1">@item.Product?.Name</h6>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="cart-item-price small">@((item.Product?.Price ?? 0).ToString("N0"))đ</span>
                        <div class="quantity-control-mini d-flex align-items-center gap-2">
                             <span class="text-muted small">x @item.Quantity</span>
                        </div>
                    </div>
                </div>
                <button class="btn btn-link text-danger p-0 ms-2" title="Xóa" 
                        onclick="removeFromCart(@item.ProductId, '@item.SelectedSize', '@item.SelectedColor')">
                    <i class="fas fa-trash-alt small"></i>
                </button>
            </div>
        }

        <div class="side-cart-footer mt-4 pt-3 border-top">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-bold">Tổng cộng:</span>
                <span class="text-primary fw-800 fs-5">@(Model.Sum(i => i.Quantity * (i.Product?.Price ?? 0)).ToString("N0"))đ</span>
            </div>
            <div class="d-grid gap-2">
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary rounded-pill fw-bold">Xem giỏ hàng</a>
                <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary rounded-pill fw-bold">Thanh toán ngay</a>
            </div>
        </div>
    }
</div>

<style>
    .quantity-control-mini { background: #f8fafc; padding: 2px 8px; border-radius: 20px; }
    .fw-800 { font-weight: 800; }
</style>
