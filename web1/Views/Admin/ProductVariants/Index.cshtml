@model IEnumerable<web1.Models.ProductVariant>
@{
    ViewData["Title"] = "Quản lý biến thể";
    var product = ViewBag.Product as web1.Models.Product;
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Quản lý biến thể</h4>
            <span class="text-muted small">
                Sản phẩm: <strong>@(product?.Name ?? "Không tìm thấy")</strong>
                @if (product != null)
                {
                    <span> — Giá gốc: <strong>@((product.Price ?? 0).ToString("N0"))đ</strong></span>
                }
            </span>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="ProductVariantCreate" asp-route-productId="@ViewBag.ProductId"
               class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>Thêm biến thể
            </a>
            <a asp-action="ProductEdit" asp-route-id="@ViewBag.ProductId"
               class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>Quay lại sản phẩm
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Success"]</div>
    }
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Message"]</div>
    }

    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 50px;">#</th>
                            <th>Size</th>
                            <th>Màu sắc</th>
                            <th class="text-end">Tồn kho</th>
                            <th class="text-end">Phụ phí</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center" style="width: 120px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var basePrice = product?.Price ?? 0;
                            int stt = 1;
                        }
                        @foreach (var item in Model)
                        {
                            var effectivePrice = basePrice + (item.PriceModifier ?? 0);
                            <tr class="@(item.Stock <= 0 ? "table-secondary" : "")">
                                <td class="text-center text-muted small">@stt</td>
                                <td>
                                    <span class="badge bg-dark rounded-pill">@item.Size</span>
                                </td>
                                <td>
                                    <span class="text-capitalize">@item.Color</span>
                                </td>
                                <td class="text-end">
                                    @if (item.Stock <= 0)
                                    {
                                        <span class="text-danger fw-bold">Hết hàng</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold">@item.Stock</span>
                                    }
                                </td>
                                <td class="text-end text-muted small">
                                    @(item.PriceModifier.HasValue
                                        ? (item.PriceModifier >= 0 ? "+" : "") + item.PriceModifier.Value.ToString("N0") + "đ"
                                        : "—")
                                </td>
                                <td class="text-end fw-bold text-primary">
                                    @effectivePrice.ToString("N0")đ
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ẩn</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="ProductVariantEdit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="ProductVariantDelete" asp-route-id="@item.Id" method="post"
                                          class="d-inline" onsubmit="return confirm('Xóa biến thể Size '@item.Size' - '@item.Color'?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            stt++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 p-3 bg-light rounded small">
            <strong>Tổng tồn kho biến thể:</strong> @Model.Sum(v => v.Stock)
            &nbsp;|&nbsp;
            <strong>Biến thể có hàng:</strong> @Model.Count(v => v.Stock > 0)
            &nbsp;|&nbsp;
            <strong>Biến thể ẩn:</strong> @Model.Count(v => !v.IsActive)
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-box-open fa-3x mb-3"></i>
            <p>Chưa có biến thể nào cho sản phẩm này.</p>
            <a asp-action="ProductVariantCreate" asp-route-productId="@ViewBag.ProductId"
               class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Thêm biến thể đầu tiên
            </a>
        </div>
    }
</div>
