@model web1.Models.ProductVariant
@{
    ViewData["Title"] = "Sửa biến thể";
    var basePrice = Model.Product?.Price ?? 0;
    var effectivePrice = basePrice + (Model.PriceModifier ?? 0);
}

<div class="container py-4" style="max-width: 600px;">
    <h4 class="fw-bold mb-1">Sửa biến thể</h4>
    <p class="text-muted small mb-3">
        Giá gốc sản phẩm: <strong>@basePrice.ToString("N0")đ</strong> →
        Giá bán biến thể: <strong class="text-primary">@effectivePrice.ToString("N0")đ</strong>
    </p>

    <div class="card shadow-sm">
        <div class="card-body">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />
                <input type="hidden" name="ProductId" value="@Model.ProductId" />

                <!-- Size -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Size <span class="text-danger">*</span></label>
                    <input type="text" name="Size" class="form-control"
                           value="@Model.Size" required>
                </div>

                <!-- Color -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Màu sắc <span class="text-danger">*</span></label>
                    <input type="text" name="Color" class="form-control"
                           value="@Model.Color" required>
                </div>

                <!-- Stock -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Tồn kho</label>
                    <input type="number" name="Stock" class="form-control"
                           min="0" value="@Model.Stock" required>
                    @if (Model.Stock <= 0)
                    {
                        <div class="text-danger small mt-1">Hết hàng — khách không thể mua biến thể này.</div>
                    }
                </div>

                <!-- Price Modifier -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Phụ phí</label>
                    <input type="number" name="PriceModifier" class="form-control"
                           step="1000"
                           value="@(Model.PriceModifier?.ToString() ?? "")">
                    <div class="form-text small text-muted">
                        Để trống hoặc 0 = giá bằng giá gốc (@basePrice.ToString("N0")đ).
                    </div>
                </div>

                <!-- IsActive -->
                <div class="mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="IsActive" id="IsActive"
                               value="true" @(Model.IsActive ? "checked" : "")>
                        <label class="form-check-label" for="IsActive">
                            <strong>Hoạt động</strong>
                        </label>
                    </div>
                </div>

                @if (ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger py-2 small">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Lưu thay đổi
                    </button>
                    <a asp-action="ProductVariants" asp-route-productId="@Model.ProductId"
                       class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>