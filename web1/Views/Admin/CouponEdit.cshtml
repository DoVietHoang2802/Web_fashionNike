@model Coupon
@{
    ViewData["Title"] = "Chỉnh sửa mã giảm giá";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="page-title fw-bold text-dark"><i class="fas fa-edit me-2 text-primary opacity-75"></i>Chỉnh sửa mã giảm giá</h2>
        <p class="text-muted small mb-0 font-inter">Cập nhật thông tin ưu đãi và quy tắc sử dụng cho mã <strong>@Model.Code</strong>.</p>
    </div>
    <a href="@Url.Action("Coupons", "Admin")" class="btn-admin btn-secondary">
        <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
</div>

<div class="row justify-content-center pt-2">
    <div class="col-xl-10">
        <div class="admin-card p-4 p-md-5">
            <form method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UsedCount" />
                
                <div class="row g-4 mb-5">
                    <!-- Left Column: Core Info -->
                    <div class="col-lg-6">
                        <h5 class="fw-bold mb-4 text-dark border-start border-4 border-primary ps-3">Thông tin ưu đãi</h5>
                        
                        <div class="admin-form-group mb-4">
                            <label class="admin-label fw-bold mb-2">Mã giảm giá</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 rounded-start-4"><i class="fas fa-lock text-muted"></i></span>
                                <input type="text" asp-for="Code" class="form-control admin-input bg-light rounded-end-4" 
                                       readonly style="text-transform:uppercase" />
                            </div>
                            <div class="extra-small text-muted mt-1 px-2">Mã giảm giá cố định và không thể thay đổi.</div>
                        </div>

                        <div class="admin-form-group mb-4">
                            <label class="admin-label fw-bold mb-2">Mô tả chương trình</label>
                            <textarea asp-for="Description" class="form-control admin-input rounded-4" rows="2">@Model.Description</textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Loại giảm giá</label>
                                    <select asp-for="DiscountType" class="form-select admin-select rounded-4">
                                        <option value="0">Phần trăm (%)</option>
                                        <option value="1">Tiền mặt (VNĐ)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Giá trị giảm <span class="text-danger">*</span></label>
                                    <input type="number" asp-for="DiscountValue" class="form-control admin-input rounded-4" 
                                           min="1" required />
                                    <span asp-validation-for="DiscountValue" class="text-danger extra-small mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-form-group mb-4">
                            <label class="admin-label fw-bold mb-2">Giảm tối đa (VNĐ)</label>
                            <input type="number" asp-for="MaxDiscount" class="form-control admin-input rounded-4" min="0" />
                            <div class="extra-small text-muted mt-2 px-2">
                                <i class="fas fa-info-circle me-1"></i> Chỉ áp dụng khi loại giảm giá là <strong>%</strong>.
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Rules & Status -->
                    <div class="col-lg-6">
                        <h5 class="fw-bold mb-4 text-dark border-start border-4 border-primary ps-3">Giới hạn & Trạng thái</h5>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Đơn hàng tối thiểu</label>
                                    <input type="number" asp-for="MinOrderAmount" class="form-control admin-input rounded-4" min="0" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Tổng lượt dùng</label>
                                    <input type="number" asp-for="MaxUsageCount" class="form-control admin-input rounded-4" min="1" />
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Ngày bắt đầu</label>
                                    <input type="date" asp-for="StartDate" class="form-control admin-input rounded-4" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="admin-form-group mb-4">
                                    <label class="admin-label fw-bold mb-2">Ngày hết hạn</label>
                                    <input type="date" asp-for="ExpiredDate" class="form-control admin-input rounded-4" />
                                </div>
                            </div>
                        </div>

                        <div class="bg-light p-3 rounded-4 border border-white mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3">
                                        <i class="fas fa-chart-line"></i>
                                    </div>
                                    <div>
                                        <div class="extra-small text-muted mb-0">Hiệu quả sử dụng</div>
                                        <div class="fw-bold text-dark fs-5">@Model.UsedCount <small class="text-muted fw-normal" style="font-size: 0.75rem;">lượt dùng</small></div>
                                    </div>
                                </div>
                                @{
                                    var percent = Model.MaxUsageCount > 0 ? (Model.UsedCount * 100 / Model.MaxUsageCount) : 0;
                                }
                                <div class="text-end">
                                    <div class="fw-bold text-primary">@percent%</div>
                                    <div class="extra-small text-muted">Đã lấp đầy</div>
                                </div>
                            </div>
                            <div class="progress mt-2" style="height: 6px;">
                                <div class="progress-bar bg-primary" style="width: @percent%"></div>
                            </div>
                        </div>

                        <div class="admin-form-group pt-2">
                            <div class="form-check form-switch custom-switch p-3 rounded-4 bg-light border border-white">
                                <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsActive" id="isActiveSwitch">
                                <label class="form-check-label fw-bold text-dark cursor-pointer" for="isActiveSwitch">Trạng thái mã: Kích hoạt</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 mt-4">
                    <button type="submit" class="btn-admin btn-primary px-5 py-3 rounded-pill shadow-lg">
                        <i class="fas fa-save me-2"></i> Lưu thay đổi
                    </button>
                    <a href="@Url.Action("Coupons", "Admin")" class="btn-admin btn-secondary px-5 py-3 rounded-pill">
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .custom-switch {
        display: flex;
        align-items: center;
        transition: all 0.3s ease;
    }
    .custom-switch:hover {
        background: rgba(99, 102, 241, 0.05) !important;
        border-color: rgba(99, 102, 241, 0.2) !important;
    }
    .form-check-input:checked {
        background-color: #6366f1;
        border-color: #6366f1;
    }
    .admin-input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
    }
</style>
