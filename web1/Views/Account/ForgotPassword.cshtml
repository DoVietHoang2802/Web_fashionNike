@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-5">
                <i class="fas fa-key fa-3x text-nike-gray mb-3"></i>
                <h2 class="fw-black text-uppercase">Quên mật khẩu?</h2>
                <p class="text-nike-gray small">Nhập đúng họ tên và email đã đăng ký để đặt lại mật khẩu.</p>
            </div>

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger border-0 rounded-0 py-3 px-4 mb-4">
                    <i class="fas fa-exclamation-circle me-2"></i> @ViewData["Error"]
                </div>
            }

            <form method="post" class="border-nike bg-white p-4">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase">Họ tên</label>
                    <input type="text" name="fullName" class="form-control border-nike rounded-0 py-3 px-3"
                           placeholder="Nhập họ tên đã đăng ký" required>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase">Email</label>
                    <input type="email" name="email" class="form-control border-nike rounded-0 py-3 px-3"
                           placeholder="Nhập email đã đăng ký" required>
                </div>

                <button type="submit" class="btn-nike w-100 py-3 text-uppercase fw-black">
                    <i class="fas fa-paper-plane me-2"></i> Tiếp tục
                </button>

                <div class="text-center mt-4">
                    <a asp-action="Login" class="text-nike-gray small fw-bold text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 900 !important; }
    .border-nike { border: 1.5px solid #e5e5e5 !important; }
</style>
