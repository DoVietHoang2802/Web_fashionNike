@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-5">
                <i class="fas fa-lock fa-3x text-nike-gray mb-3"></i>
                <h2 class="fw-black text-uppercase">Đặt mật khẩu mới</h2>
                <p class="text-nike-gray small">Nhập mật khẩu mới cho tài khoản <strong>@ViewData["ResetEmail"]</strong></p>
            </div>

            @if (ViewData["Error"] != null)
            {
                <div class="alert alert-danger border-0 rounded-0 py-3 px-4 mb-4">
                    <i class="fas fa-exclamation-circle me-2"></i> @ViewData["Error"]
                </div>
            }

            <form method="post" class="border-nike bg-white p-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@ViewData["ResetEmail"]" />

                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase">Mật khẩu mới</label>
                    <input type="password" name="newPassword" class="form-control border-nike rounded-0 py-3 px-3"
                           placeholder="Tối thiểu 6 ký tự" required minlength="6">
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold text-uppercase">Xác nhận mật khẩu</label>
                    <input type="password" name="confirmPassword" class="form-control border-nike rounded-0 py-3 px-3"
                           placeholder="Nhập lại mật khẩu mới" required minlength="6">
                </div>

                <button type="submit" class="btn-nike w-100 py-3 text-uppercase fw-black">
                    <i class="fas fa-check me-2"></i> Đặt lại mật khẩu
                </button>

                <div class="text-center mt-4">
                    <a asp-action="Login" class="text-nike-gray small fw-bold text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 900 !important; }
    .border-nike { border: 1.5px solid #e5e5e5 !important; }
</style>
