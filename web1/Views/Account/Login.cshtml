@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="p-4 border-nike bg-white">
                <div class="text-center mb-5">
                    <h2 class="fw-black text-uppercase">ĐĂNG NHẬP</h2>
                </div>

                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase">Email</label>
                        <input type="email" name="email" class="form-control border-nike rounded-0 py-3 px-3"
                               placeholder="Địa chỉ Email" required autofocus>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-uppercase">Mật khẩu</label>
                        <input type="password" name="password" class="form-control border-nike rounded-0 py-3 px-3"
                               placeholder="Mật khẩu của bạn" required>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-dark border-0 rounded-0 small mb-4 py-2">
                            @foreach (var modelError in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div class="fw-bold">@modelError.ErrorMessage</div>
                            }
                        </div>
                    }

                    <div class="mb-4 text-center">
                        <p class="text-nike-gray extra-small text-uppercase">
                            Bằng cách đăng nhập, bạn đồng ý với <a href="#" class="text-nike-black fw-bold">Chính sách bảo mật</a> và <a href="#" class="text-nike-black fw-bold">Điều khoản sử dụng</a> của Nike.
                        </p>
                    </div>

                    <button type="submit" class="btn-nike w-100 py-3 text-uppercase fw-black mb-4">
                        Đăng nhập
                    </button>

                    <div class="text-center border-top pt-4">
                        <span class="text-nike-gray small">Chưa là thành viên?</span>
                        <a asp-action="Register" asp-route-returnUrl="@returnUrl" class="text-nike-black fw-bold text-decoration-none small ms-1 text-uppercase">
                            Tham gia ngay
                        </a>

                        <div class="mt-3">
                            <a asp-action="ForgotPassword" class="text-nike-gray small text-decoration-none">
                                <i class="fas fa-key me-1"></i> Quên mật khẩu?
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 900 !important; }
    .extra-small { font-size: 0.7rem; }
</style>
