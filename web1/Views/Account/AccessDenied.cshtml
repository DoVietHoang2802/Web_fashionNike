@{
    ViewData["Title"] = "Không có quyền truy cập";
}
<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <i class="fas fa-lock fa-5x text-danger mb-4"></i>
            <h2 class="text-danger mb-3">Không có quyền truy cập</h2>
            <p class="text-muted mb-4">
                Bạn không có quyền truy cập trang này. Vui lòng đăng nhập bằng tài khoản có quyền phù hợp.
            </p>
            <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-home me-2"></i>Về trang chủ
                </a>
                <a asp-action="Login" class="btn btn-primary">
                    <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
                </a>
            </div>
        </div>
    </div>
</div>
